{
  "servers": {
    "json": {
      "command": "vscode-json-language-server",
      "args": [
        "--stdio"
      ]
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": [
        "--stdio"
      ]
    },
    "bash": {
      "command": "bash-language-server",
      "args": [
        "start"
      ]
    },
    "markdown": {
      "command": "marksman",
      "args": [
        "server"
      ]
    },
    "python": {
      "command": "basedpyright-langserver",
      "args": [
        "--stdio"
      ]
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": [
        "--stdio"
      ]
    }
  },
  "fileExtensions": {
    ".json": "json",
    ".jsonc": "json",
    ".code-workspace": "json",
    ".yaml": "yaml",
    ".yml": "yaml",
    ".sh": "bash",
    ".bash": "bash",
    ".zsh": "bash",
    ".md": "markdown",
    ".markdown": "markdown",
    ".py": "python",
    ".pyi": "python",
    ".ts": "typescript",
    ".tsx": "typescript",
    ".mts": "typescript",
    ".cts": "typescript"
  }
}
