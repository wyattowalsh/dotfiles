[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
[pull]
    rebase = true
[push]
    autoSetupRemote = true
[init]
    defaultBranch = main
[merge]
    conflictstyle = zdiff3
[alias]
    lg = log --oneline --graph --all --decorate
    st = status -sb
    co = checkout
    br = branch --sort=-committerdate
    uncommit = reset HEAD~1
    aliases = config --get-regexp alias
